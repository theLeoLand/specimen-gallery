<div class="w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="font-serif text-4xl text-stone-900 dark:text-stone-100">Pending Queue</h1>
      <p class="text-stone-600 dark:text-stone-400 mt-1">Review and moderate specimen submissions</p>
    </div>
    <span class="px-3 py-1 bg-amber-100 dark:bg-amber-900/50 text-amber-800 dark:text-amber-300 rounded-full text-sm font-medium">
      <%= @specimen_assets.count %> pending
    </span>
  </div>

  <% if @specimen_assets.any? %>
    <div class="space-y-4">
      <% @specimen_assets.each do |specimen| %>
        <div class="bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl p-6 flex items-center gap-6">
          <div class="w-24 h-24 flex-shrink-0 bg-gradient-to-br from-stone-100 to-stone-200 dark:from-stone-700 dark:to-stone-600 rounded-xl overflow-hidden">
            <% if specimen.image.attached? %>
              <%= image_tag specimen.image,
                alt: specimen.scientific_name,
                class: "w-full h-full object-contain p-2" %>
            <% end %>
          </div>

          <div class="flex-grow min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-medium text-stone-900 dark:text-stone-100 truncate">
                <em><%= specimen.taxon&.scientific_name || "Unknown" %></em>
              </h3>
              <% if specimen.needs_review? %>
                <span class="inline-block px-2 py-0.5 bg-amber-100 dark:bg-amber-900/50 text-amber-800 dark:text-amber-300 rounded text-xs font-medium">
                  Needs review
                </span>
              <% end %>
              <% if specimen.bg_removed? %>
                <span class="inline-block px-2 py-0.5 bg-violet-100 dark:bg-violet-900/50 text-violet-800 dark:text-violet-300 rounded text-xs font-medium">
                  Cutout generated
                </span>
              <% end %>
            </div>

            <% if specimen.common_name.present? %>
              <p class="text-sm text-stone-600 dark:text-stone-400 truncate"><%= specimen.common_name %></p>
            <% end %>

            <% if specimen.taxon&.gbif_key.present? %>
              <p class="text-xs text-emerald-700 dark:text-emerald-400 mt-1">
                ✓ GBIF: <%= specimen.taxon.gbif_canonical_name %>
                (<%= specimen.taxon.gbif_rank&.downcase %>)
                <span class="text-stone-400 dark:text-stone-500">confidence <%= specimen.taxon.gbif_confidence %>%</span>
              </p>
            <% else %>
              <p class="text-xs text-amber-600 dark:text-amber-400 mt-1">
                ⚠ Not verified in GBIF
              </p>
            <% end %>

            <p class="text-xs text-stone-500 dark:text-stone-400 mt-1">
              Submitted <%= time_ago_in_words(specimen.created_at) %> ago
              · License:
              <span class="inline-block px-1.5 py-0.5 bg-stone-100 dark:bg-stone-700 text-stone-700 dark:text-stone-300 rounded text-xs">
                <%= specimen.license == "CC0" ? "CC0" : "CC-BY" %>
              </span>
            </p>
          </div>

          <div class="flex-shrink-0 flex items-center gap-3">
            <%= button_to admin_specimen_asset_path(specimen, status: "approved"),
              method: :patch,
              class: "px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-full hover:bg-emerald-700 transition-colors" do %>
              ✓ Approve
            <% end %>

            <%= button_to admin_specimen_asset_path(specimen),
              method: :delete,
              data: { turbo_confirm: "Reject and delete this specimen?" },
              class: "px-4 py-2 bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300 text-sm font-medium rounded-full hover:bg-red-200 dark:hover:bg-red-900 transition-colors" do %>
              ✗ Reject
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl">
      <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-stone-100 dark:bg-stone-700 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <p class="text-lg text-stone-600 dark:text-stone-300 mb-2">Queue is empty</p>
      <p class="text-sm text-stone-500 dark:text-stone-400">No specimens pending review.</p>
    </div>
  <% end %>
</div>
