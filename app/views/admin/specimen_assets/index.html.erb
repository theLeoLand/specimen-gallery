<div class="w-full pt-4 md:pt-0">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="font-serif text-4xl text-stone-900 dark:text-stone-100">Admin</h1>
      <p class="text-stone-600 dark:text-stone-400 mt-1">Manage specimen submissions</p>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="flex items-center gap-1 mb-6 border-b border-stone-200 dark:border-stone-700">
    <%= link_to admin_specimen_assets_path(filter: "pending"),
      class: "px-4 py-3 text-sm font-medium border-b-2 -mb-px transition-colors #{@filter == 'pending' ? 'border-amber-500 text-amber-600 dark:text-amber-400' : 'border-transparent text-stone-500 dark:text-stone-400 hover:text-stone-700 dark:hover:text-stone-300'}" do %>
      Pending
      <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs <%= @pending_count > 0 ? 'bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300' : 'bg-stone-100 dark:bg-stone-700 text-stone-500 dark:text-stone-400' %>">
        <%= @pending_count %>
      </span>
    <% end %>
    
    <%= link_to admin_specimen_assets_path(filter: "approved"),
      class: "px-4 py-3 text-sm font-medium border-b-2 -mb-px transition-colors #{@filter == 'approved' ? 'border-emerald-500 text-emerald-600 dark:text-emerald-400' : 'border-transparent text-stone-500 dark:text-stone-400 hover:text-stone-700 dark:hover:text-stone-300'}" do %>
      Live
      <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs bg-stone-100 dark:bg-stone-700 text-stone-500 dark:text-stone-400">
        <%= @approved_count %>
      </span>
    <% end %>

    <%= link_to admin_flags_path,
      class: "px-4 py-3 text-sm font-medium border-b-2 -mb-px transition-colors border-transparent text-stone-500 dark:text-stone-400 hover:text-stone-700 dark:hover:text-stone-300" do %>
      Flags
      <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs <%= @flags_count > 0 ? 'bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300' : 'bg-stone-100 dark:bg-stone-700 text-stone-500 dark:text-stone-400' %>">
        <%= @flags_count %>
      </span>
    <% end %>
  </div>

  <!-- Search bar -->
  <div class="mb-6">
    <%= form_with url: admin_specimen_assets_path, method: :get, class: "flex gap-2" do |f| %>
      <%= hidden_field_tag :filter, @filter %>
      <div class="relative flex-grow">
        <%= text_field_tag :q, params[:q],
          placeholder: "Search by name, region, morph...",
          class: "w-full pl-10 pr-4 py-2 bg-white dark:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-full text-stone-800 dark:text-stone-200 placeholder:text-stone-400 dark:placeholder:text-stone-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent text-sm" %>
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 dark:text-stone-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
      <%= f.submit "Search", class: "px-4 py-2 bg-amber-600 text-white text-sm font-medium rounded-full hover:bg-amber-700 cursor-pointer" %>
      <% if params[:q].present? %>
        <%= link_to "Clear", admin_specimen_assets_path(filter: @filter), class: "px-4 py-2 text-sm text-stone-500 hover:text-amber-600" %>
      <% end %>
    <% end %>
  </div>

  <% if params[:q].present? %>
    <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
      <%= @specimen_assets.count %> result(s) for "<%= params[:q] %>"
    </p>
  <% end %>

  <% if @specimen_assets.any? %>
    <div class="space-y-4">
      <% @specimen_assets.each do |specimen| %>
        <div class="bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl p-4 md:p-5">
          <!-- Desktop: horizontal row | Mobile: stacked -->
          <div class="flex flex-col md:flex-row md:items-center gap-4">
            <!-- Thumbnail -->
            <%= link_to (@filter == "approved" ? taxon_path(specimen.taxon) : edit_admin_specimen_asset_path(specimen)),
              class: "block w-16 h-16 md:w-20 md:h-20 flex-shrink-0 bg-gradient-to-br from-stone-100 to-stone-200 dark:from-stone-700 dark:to-stone-600 rounded-xl overflow-hidden hover:ring-2 hover:ring-amber-400 transition-all" do %>
              <% if specimen.image.attached? %>
                <%= image_tag specimen.image,
                  alt: specimen.taxon&.scientific_name || "Specimen",
                  loading: "lazy",
                  class: "w-full h-full object-contain p-1" %>
              <% end %>
            <% end %>

            <!-- Details -->
            <div class="flex-grow min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <h3 class="font-medium text-stone-900 dark:text-stone-100 truncate">
                  <%= specimen.display_name %>
                </h3>
                <% if @filter == "pending" && specimen.needs_review? %>
                  <span class="px-2 py-0.5 bg-amber-100 dark:bg-amber-900/50 text-amber-800 dark:text-amber-300 rounded text-xs font-medium">Needs review</span>
                <% end %>
                <% if specimen.profanity_flagged? %>
                  <span class="px-2 py-0.5 bg-red-100 dark:bg-red-900/50 text-red-800 dark:text-red-300 rounded text-xs font-medium">⚠ Flagged</span>
                <% end %>
                <% if specimen.bg_removed? %>
                  <span class="px-2 py-0.5 bg-violet-100 dark:bg-violet-900/50 text-violet-800 dark:text-violet-300 rounded text-xs font-medium">Cutout</span>
                <% end %>
              </div>

              <% if specimen.taxon&.gbif_key.present? && specimen.specimen_name != specimen.taxon.scientific_name %>
                <p class="text-sm text-stone-600 dark:text-stone-400 truncate italic"><%= specimen.taxon.scientific_name %></p>
              <% elsif specimen.common_name.present? && specimen.common_name != specimen.specimen_name %>
                <p class="text-sm text-stone-600 dark:text-stone-400 truncate"><%= specimen.common_name %></p>
              <% end %>

              <% if @filter == "pending" %>
                <% if TaxonGroupResolver.non_living?(specimen.taxon&.group) %>
                  <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">GBIF n/a (non-living)</p>
                <% elsif specimen.taxon&.gbif_key.present? %>
                  <p class="text-xs text-emerald-700 dark:text-emerald-400 mt-0.5">✓ <%= specimen.taxon.gbif_canonical_name %></p>
                <% elsif specimen.taxon&.scientific_name.present? && specimen.taxon.scientific_name != specimen.specimen_name %>
                  <p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">⚠ Not verified</p>
                <% end %>
              <% end %>

              <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">
                <%= @filter == "approved" ? "Approved" : "Submitted" %> <%= time_ago_in_words(specimen.created_at) %> ago ·
                <span class="px-1 py-0.5 bg-stone-100 dark:bg-stone-700 rounded"><%= specimen.license == "CC0" ? "CC0" : "CC-BY" %></span>
              </p>
            </div>

            <!-- Actions: inline on desktop, below on mobile -->
            <div class="flex flex-wrap gap-2 pt-3 border-t border-stone-200 dark:border-stone-700 md:pt-0 md:border-0 md:flex-shrink-0">
              <% if @filter == "pending" %>
                <%= link_to edit_admin_specimen_asset_path(specimen),
                  class: "px-3 py-1.5 border border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-400 text-sm font-medium rounded-full hover:bg-stone-100 dark:hover:bg-stone-700 transition-colors" do %>
                  Edit
                <% end %>
                <%= button_to admin_specimen_asset_path(specimen, status: "approved"),
                  method: :patch,
                  class: "px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-full hover:bg-emerald-700 transition-colors" do %>
                  ✓ Approve
                <% end %>
                <%= button_to admin_specimen_asset_path(specimen),
                  method: :delete,
                  data: { turbo_confirm: "Reject and delete this specimen?" },
                  class: "px-3 py-1.5 bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300 text-sm font-medium rounded-full hover:bg-red-200 dark:hover:bg-red-900 transition-colors" do %>
                  ✗ Reject
                <% end %>
              <% else %>
                <%= link_to taxon_path(specimen.taxon),
                  class: "px-3 py-1.5 border border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-400 text-sm font-medium rounded-full hover:bg-stone-100 dark:hover:bg-stone-700 transition-colors",
                  target: "_blank" do %>
                  View
                <% end %>
                <%= button_to unpublish_admin_specimen_asset_path(specimen),
                  method: :patch,
                  data: { turbo_confirm: "Move this back to Pending for review?" },
                  class: "px-3 py-1.5 bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300 text-sm font-medium rounded-full hover:bg-amber-200 dark:hover:bg-amber-800 transition-colors" do %>
                  Unpublish
                <% end %>
                <%= button_to admin_specimen_asset_path(specimen),
                  method: :delete,
                  data: { turbo_confirm: "Remove this specimen from the gallery? This cannot be undone." },
                  class: "px-3 py-1.5 bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300 text-sm font-medium rounded-full hover:bg-red-200 dark:hover:bg-red-900 transition-colors" do %>
                  Remove
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl">
      <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-stone-100 dark:bg-stone-700 flex items-center justify-center">
        <% if @filter == "approved" %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
          </svg>
        <% end %>
      </div>
      <% if @filter == "approved" %>
        <p class="text-lg text-stone-600 dark:text-stone-300 mb-2">No live specimens</p>
        <p class="text-sm text-stone-500 dark:text-stone-400">Approved specimens will appear here.</p>
      <% else %>
        <p class="text-lg text-stone-600 dark:text-stone-300 mb-2">Queue is empty</p>
        <p class="text-sm text-stone-500 dark:text-stone-400">No specimens pending review.</p>
      <% end %>
    </div>
  <% end %>
</div>
