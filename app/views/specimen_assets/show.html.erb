<% content_for(:title) { "#{@specimen_asset.display_name} — Specimen Gallery" } %>
<% content_for(:meta_description) { "Free CC0 transparent-background cutout of #{@specimen_asset.display_name}. Download high-quality PNG for illustration, research, and design." } %>
<% content_for(:og_title) { "#{@specimen_asset.display_name} — Free CC0 Specimen Cutout" } %>
<% content_for(:og_description) { "Download a free transparent-background PNG of #{@specimen_asset.display_name}. CC0 public domain — no attribution required." } %>
<% if @specimen_asset.image.attached? %>
  <% content_for(:og_image) { url_for(@specimen_asset.image) } %>
<% end %>

<div class="max-w-4xl mx-auto">
  <!-- Back link -->
  <div class="mb-6">
    <%= link_to "← Back to #{@specimen_asset.taxon.scientific_name}", taxon_path(@specimen_asset.taxon),
      class: "text-amber-600 dark:text-amber-500 hover:underline text-sm" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Image -->
    <div class="bg-gradient-to-br from-stone-100 to-stone-200 dark:from-stone-700 dark:to-stone-600 rounded-2xl p-6 flex items-center justify-center min-h-[400px]">
      <% if @specimen_asset.image.attached? %>
        <%= image_tag @specimen_asset.image,
          alt: specimen_alt_text(@specimen_asset),
          class: "max-w-full max-h-[500px] object-contain" %>
      <% else %>
        <div class="text-stone-500">No image available</div>
      <% end %>
    </div>

    <!-- Details -->
    <div class="space-y-6">
      <!-- Header -->
      <div>
        <h1 class="font-serif text-3xl text-stone-900 dark:text-stone-100 mb-2">
          <%= @specimen_asset.display_name %>
        </h1>
        <% if @specimen_asset.taxon.scientific_name != @specimen_asset.display_name %>
          <p class="text-lg text-stone-600 dark:text-stone-400 italic">
            <%= @specimen_asset.taxon.scientific_name %>
          </p>
        <% end %>
        <% if @specimen_asset.common_name.present? %>
          <p class="text-stone-500 dark:text-stone-400"><%= @specimen_asset.common_name %></p>
        <% end %>
      </div>

      <!-- Trait chips -->
      <% if @specimen_asset.trait_chips.any? %>
        <div class="flex flex-wrap gap-2">
          <% @specimen_asset.trait_chips.each do |chip| %>
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-stone-100 dark:bg-stone-700 text-stone-600 dark:text-stone-300">
              <%= chip[:label] %>
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Community ID Widget -->
      <%= render "specimen_assets/consensus_widget", specimen_asset: @specimen_asset %>

      <!-- Vote feedback area -->
      <div id="vote_feedback"></div>

      <!-- Voting actions -->
      <div class="bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-xl p-4 space-y-4">
        <h3 class="font-medium text-stone-900 dark:text-stone-100">Help verify this ID</h3>
        
        <!-- Confirm button -->
        <%= button_to "Confirm ID", confirm_id_specimen_asset_path(@specimen_asset),
          method: :post,
          class: "w-full px-4 py-2 bg-emerald-600 text-white font-medium rounded-lg hover:bg-emerald-700 transition-colors",
          data: { turbo_stream: true } %>

        <!-- Suggest different ID -->
        <details class="group">
          <summary class="cursor-pointer text-sm text-amber-600 dark:text-amber-500 hover:underline">
            Suggest a different identification →
          </summary>
          <div class="mt-3 space-y-3" data-controller="taxon-autocomplete" data-taxon-autocomplete-url-value="<%= suggest_taxa_path %>">
            <%= form_with url: suggest_id_specimen_asset_path(@specimen_asset), method: :post, data: { turbo_stream: true } do |f| %>
              <div class="relative">
                <%= f.text_field :suggested_taxon_name,
                  placeholder: "Search for a taxon...",
                  autocomplete: "off",
                  data: {
                    taxon_autocomplete_target: "input",
                    action: "input->taxon-autocomplete#onInput keydown->taxon-autocomplete#onKeydown blur->taxon-autocomplete#onBlur"
                  },
                  class: "w-full px-3 py-2 bg-white dark:bg-stone-700 border border-stone-300 dark:border-stone-600 rounded-lg text-stone-800 dark:text-stone-200 text-sm placeholder:text-stone-400" %>
                <div data-taxon-autocomplete-target="results"
                     class="hidden absolute z-50 left-0 right-0 mt-1 bg-white dark:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-lg shadow-lg max-h-48 overflow-y-auto text-sm">
                </div>
              </div>
              <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">Start typing to search GBIF taxonomy</p>
              <%= f.submit "Submit Suggestion",
                class: "mt-2 w-full px-4 py-2 bg-amber-600 text-white font-medium rounded-lg hover:bg-amber-700 transition-colors text-sm cursor-pointer" %>
            <% end %>
          </div>
        </details>
      </div>

      <!-- Metadata -->
      <div class="text-sm text-stone-500 dark:text-stone-400 space-y-1">
        <p>License: <%= @specimen_asset.license == "CC0" ? "CC0 (Public Domain)" : "CC-BY" %></p>
        <% if @specimen_asset.license == "CC_BY" && @specimen_asset.attribution_name.present? %>
          <p>
            Attribution:
            <% if @specimen_asset.attribution_url.present? %>
              <%= link_to @specimen_asset.attribution_name, @specimen_asset.attribution_url,
                target: "_blank", rel: "noopener",
                class: "text-amber-600 dark:text-amber-500 hover:underline" %>
            <% else %>
              <%= @specimen_asset.attribution_name %>
            <% end %>
          </p>
        <% end %>
        <% if @specimen_asset.notes.present? %>
          <p class="mt-2 text-stone-600 dark:text-stone-300"><%= @specimen_asset.notes %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

