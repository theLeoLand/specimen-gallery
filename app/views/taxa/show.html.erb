<div class="w-full">
  <%= link_to "← Back to Gallery", browse_path(id_status: @id_status_filter), class: "inline-block text-sm text-stone-600 dark:text-stone-400 hover:text-amber-700 dark:hover:text-amber-500 mb-8 transition-colors" %>

  <div class="mb-8">
    <h1 class="font-serif text-4xl text-stone-900 dark:text-stone-100 mb-2 italic">
      <%= @taxon.scientific_name %>
    </h1>
    <% if @taxon.gbif_rank.present? %>
      <p class="text-stone-500 dark:text-stone-400 text-sm mb-1">Rank: <%= @taxon.gbif_rank.downcase %></p>
    <% end %>
    <% if @taxon.taxon_source.present? && @taxon.taxon_id.present? %>
      <p class="text-stone-500 dark:text-stone-400 text-sm">
        <%= @taxon.taxon_source.upcase %> #<%= @taxon.taxon_id %>
      </p>
    <% end %>
    <p class="text-stone-600 dark:text-stone-400 mt-2">
      <%= pluralize(@specimen_assets.count, "image") %>
      <% if @id_status_filter.present? && @id_status_filter != "all" %>
        <span class="text-stone-400">
          (showing <%= @id_status_filter %> only — <%= link_to "view all", taxon_path(@taxon), class: "text-amber-600 hover:underline" %>)
        </span>
      <% end %>
    </p>
  </div>

  <% if @specimen_assets.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @specimen_assets.each do |specimen| %>
        <div class="bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl overflow-hidden">
          <%= link_to specimen_asset_path(specimen), class: "block" do %>
            <div class="aspect-square bg-gradient-to-br from-stone-100 to-stone-200 dark:from-stone-700 dark:to-stone-600 p-6 relative">
              <% if specimen.image.attached? %>
                <%= image_tag specimen.image,
                  alt: @taxon.scientific_name,
                  class: "w-full h-full object-contain" %>
              <% end %>
              <% if specimen.verified? %>
                <span class="absolute top-2 right-2 px-2 py-0.5 text-xs font-medium rounded-full <%= specimen.id_status_badge_class %>">
                  Verified
                </span>
              <% end %>
            </div>
          <% end %>

          <div class="p-4 space-y-2">
            <div class="flex items-center justify-between">
              <%= link_to specimen_asset_path(specimen), class: "hover:text-amber-600 transition-colors" do %>
                <p class="font-medium text-stone-800 dark:text-stone-200"><%= specimen.specimen_name %></p>
              <% end %>
              <%= render "shared/flag_menu", specimen: specimen %>
            </div>

            <!-- Trait chips -->
            <% if specimen.trait_chips.any? %>
              <div class="flex flex-wrap gap-1">
                <% specimen.trait_chips.first(3).each do |chip| %>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-stone-100 dark:bg-stone-700 text-stone-500 dark:text-stone-400">
                    <%= chip[:label] %>
                  </span>
                <% end %>
                <% if specimen.trait_chips.size > 3 %>
                  <span class="px-2 py-0.5 text-xs text-stone-400">+<%= specimen.trait_chips.size - 3 %></span>
                <% end %>
              </div>
            <% end %>

            <div class="flex items-center justify-between">
              <% if specimen.license == "CC0" %>
                <span class="inline-block px-2 py-1 bg-emerald-100 dark:bg-emerald-900/50 text-emerald-800 dark:text-emerald-300 rounded text-xs font-medium">CC0</span>
              <% else %>
                <span class="inline-block px-2 py-1 bg-amber-100 dark:bg-amber-900/50 text-amber-800 dark:text-amber-300 rounded text-xs font-medium">CC-BY</span>
              <% end %>

              <% if specimen.image.attached? %>
                <%= link_to rails_blob_path(specimen.image, disposition: "attachment"),
                  class: "text-xs text-stone-500 dark:text-stone-400 hover:text-amber-700 dark:hover:text-amber-500 transition-colors" do %>
                  Download ↓
                <% end %>
              <% end %>
            </div>

            <% if specimen.license == "CC_BY" && specimen.attribution_name.present? %>
              <p class="text-xs text-stone-500 dark:text-stone-400">
                Credit:
                <% if specimen.attribution_url.present? %>
                  <%= link_to specimen.attribution_name, specimen.attribution_url,
                    target: "_blank", rel: "noopener",
                    class: "text-amber-700 dark:text-amber-500 hover:underline" %>
                <% else %>
                  <%= specimen.attribution_name %>
                <% end %>
              </p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-2xl">
      <p class="text-stone-500 dark:text-stone-400">No specimens match these filters.</p>
      <%= link_to "Clear filters", taxon_path(@taxon),
        class: "mt-2 inline-block text-amber-600 hover:underline" %>
    </div>
  <% end %>
</div>
