<%# Flag menu with modal for specimen assets %>
<%# Usage: render "shared/flag_menu", specimen: @specimen_asset %>

<div class="relative" data-controller="flag-modal" data-flag-modal-url-value="<%= specimen_asset_flags_path(specimen) %>">
  <!-- Kebab menu button -->
  <button
    type="button"
    data-action="click->flag-modal#open"
    class="p-1.5 text-stone-400 hover:text-stone-600 dark:hover:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-700 rounded-full transition-colors"
    title="Report an issue"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
    </svg>
  </button>

  <!-- Modal backdrop -->
  <div
    data-flag-modal-target="modal"
    data-action="click->flag-modal#closeOnBackdrop"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
  >
    <!-- Modal content -->
    <div class="bg-white dark:bg-stone-800 rounded-2xl shadow-xl w-full max-w-md mx-4 p-6" data-action="click->flag-modal#stopPropagation">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-medium text-stone-900 dark:text-stone-100">Report an Issue</h3>
        <button
          type="button"
          data-action="click->flag-modal#close"
          class="text-stone-400 hover:text-stone-600 dark:hover:text-stone-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <!-- Form -->
      <form data-flag-modal-target="form" data-action="submit->flag-modal#submit" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-2">
            What's the issue?
          </label>
          <select
            data-flag-modal-target="reason"
            required
            class="w-full px-4 py-3 bg-white dark:bg-stone-700 border border-stone-300 dark:border-stone-600 rounded-xl text-stone-800 dark:text-stone-200 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent"
          >
            <option value="">Select a reason...</option>
            <option value="wrong_name">Wrong name/identification</option>
            <option value="wrong_license">Incorrect license</option>
            <option value="inappropriate">Inappropriate content</option>
            <option value="duplicate">Duplicate submission</option>
            <option value="low_quality">Low quality image</option>
            <option value="other">Other issue</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-stone-700 dark:text-stone-300 mb-2">
            Additional details <span class="text-stone-400 font-normal">(optional)</span>
          </label>
          <textarea
            data-flag-modal-target="details"
            rows="3"
            placeholder="Please provide any helpful details..."
            class="w-full px-4 py-3 bg-white dark:bg-stone-700 border border-stone-300 dark:border-stone-600 rounded-xl text-stone-800 dark:text-stone-200 placeholder:text-stone-400 dark:placeholder:text-stone-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none"
          ></textarea>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="button"
            data-action="click->flag-modal#close"
            class="flex-1 px-4 py-2.5 border border-stone-300 dark:border-stone-600 text-stone-600 dark:text-stone-400 text-sm font-medium rounded-full hover:bg-stone-100 dark:hover:bg-stone-700 transition-colors"
          >
            Cancel
          </button>
          <button
            type="submit"
            data-flag-modal-target="submitBtn"
            class="flex-1 px-4 py-2.5 bg-amber-600 text-white text-sm font-medium rounded-full hover:bg-amber-700 transition-colors disabled:opacity-50"
          >
            Submit Report
          </button>
        </div>
      </form>

      <!-- Success/error message -->
      <p data-flag-modal-target="message" class="hidden text-center py-4 font-medium"></p>
    </div>
  </div>
</div>

