# Specimen Gallery Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ===================
# Rails
# ===================
RAILS_MASTER_KEY=your_master_key_here
# Generate with: rails secret

# ===================
# Database
# ===================
DATABASE_URL=postgres://user:password@localhost:5432/specimen_gallery_development
# For local dev, you can use SQLite instead (no DATABASE_URL needed)

# ===================
# Cloudinary (Background Removal)
# ===================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Sign up at: https://cloudinary.com
# Background removal requires a paid plan or free trial credits

# ===================
# AWS S3 (Optional - for production file storage)
# ===================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_ENDPOINT_URL_S3=https://s3.us-east-1.amazonaws.com
BUCKET_NAME=your_bucket_name
# For local dev, Active Storage uses local disk by default

# ===================
# Admin Access
# ===================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
ADMIN_ROUTE_SECRET=your_route_secret
# Used for /admin routes - set strong values in production
